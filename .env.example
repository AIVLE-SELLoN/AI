# 이 파일을 .env 로 복사해서 값을 채우세요. .env 는 git 에 올라가지 않습니다.
#   cp .env.example .env

# --- LLM (OpenAI) ---
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# --- 벡터DB (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
# 로컬 파일 모드로 쓸 때만 사용. 값이 있으면 HOST/PORT 대신 이 경로를 씁니다.
CHROMA_PERSIST_DIR=.chroma

# --- 앱 ---
LOG_LEVEL=INFO
